# ============================================================
#  ResiHub environment configuration
# ============================================================
#  Copy this file to .env and fill in real values:
#      cp .env.example .env
#
#  .env is gitignored — never commit real secrets.
#  On the VPS, ./deploy.sh auto-generates strong JWT secrets into .env
#  if they're missing, so you usually don't touch this by hand there.
#
#  For LOCAL development you can leave .env empty entirely — docker-compose
#  has safe dev-only fallbacks for every value below.
# ============================================================

# ── Auth secrets (REQUIRED in production) ──────────────────────
# Generate strong values with:  openssl rand -hex 32
# Rotating these logs every signed-in user out — that's expected.
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# ── Database ───────────────────────────────────────────────────
# POSTGRES_PASSWORD is only read when the postgres volume is first
# created. To rotate it on an existing DB you must ALTER the role
# inside psql (or recreate the volume) — see deploy notes.
POSTGRES_PASSWORD=resihub

# ── Runtime ────────────────────────────────────────────────────
NODE_ENV=production
# Public origin of the SPA — used for CORS. On the VPS this is the
# real domain; locally it's http://localhost:3000.
FRONTEND_URL=https://resihub.athera.co.za

# ── Frontend ───────────────────────────────────────────────────
# Host port the frontend container is published on. The VPS already
# runs another app on :3000, so it uses :3001 there.
FRONTEND_PORT=3001
# API base URL baked into the SPA build. "/api" means same-origin
# (nginx proxies /api/* to the backend) — correct for the VPS.
# Locally, leave unset to default to http://localhost:5000/api.
VITE_API_BASE_URL=/api
