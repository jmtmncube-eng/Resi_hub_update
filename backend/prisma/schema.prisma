// ResiHub — Prisma Schema
// Database: PostgreSQL 15+
// Last Updated: 2026-05-01

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════════════════════
// ENUMS
// ═══════════════════════════════════════════════════════════════

enum Role {
  ACTIVE_STUDENT
  PENDING_STUDENT
  ADMIN
  // ── Staff roles — delegate operational work without full ownership ──
  MANAGER      // admin-lite: all day-to-day ops; no audit log, no residence
               // settings, can't change roles or touch admin/manager accounts
  MAINTENANCE  // handyman: maintenance tickets + ops service logs only
}

enum RoomType {
  SINGLE
  DOUBLE
  TRIPLE
  QUAD
  STUDIO
}

enum RoomStatus {
  VACANT
  RESERVED
  OCCUPIED
}

enum AllocationStatus {
  RESERVED
  ACTIVE
  ENDED
}

// Where a tenant's security deposit stands in the lease lifecycle.
enum DepositStatus {
  NONE                // no deposit recorded yet
  HELD                // deposit paid and held by the residence
  PARTIALLY_REFUNDED  // some withheld (damages, cleaning), rest returned
  REFUNDED            // fully returned at move-out
}

// Inspection points in the lease lifecycle.
enum InspectionType {
  MOVE_IN
  ROUTINE
  MOVE_OUT
}

enum Priority {
  LOW
  NORMAL
  HIGH
  EMERGENCY
}

enum ContractorType {
  CLEANER
  GROUNDSKEEPER
  GARDENER
  OTHER
}

/// FIXED  — rate is the invoice amount each period (e.g. monthly retainer).
/// VARIABLE — rate is just a budget hint; admin enters the actual amount when
///            marking the invoice paid (e.g. per-visit cleaners, hourly work).
enum ContractorPaymentType {
  FIXED
  VARIABLE
}

/// Type of operational service / expense logged by admin.
/// Each type drives its own widget on the Operations tab.
enum OpsServiceType {
  POOL_CLEAN
  POOL_CHEMICAL
  GAS_REFILL
  GRASS_CUT
  ELECTRICITY_PURCHASE
  SOLAR_TELEMETRY
  OTHER
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum PassStatus {
  UPCOMING
  ACTIVE
  EXPIRED
  CANCELLED
}

enum ChoreAction {
  CLAIMED
  UNCLAIMED
  COMPLETED
}

enum TransactionType {
  EARN
  REDEEM
  ADJUST
}

enum DocumentType {
  INVOICE
  CONTRACT
  LETTER
  // Application documents — submitted by pending students at signup
  ID_DOC
  PROOF_REGISTRATION
  PROOF_FUNDING
  SIGNATURE
}

enum ApplicationStatus {
  DRAFT       // not yet submitted (no docs uploaded)
  SUBMITTED   // student has uploaded all required docs
  APPROVED    // admin approved
  REJECTED    // admin rejected (with note)
}

// Categorises an in-app notification — drives the icon/colour the bell
// dropdown renders. The notification's `link` is what it navigates to.
enum NotificationType {
  INVOICE         // new rent invoice raised
  CONTRACT        // lease ready to sign
  CHORE_APPROVED  // chore proof approved → credits awarded
  CHORE_REJECTED  // chore proof rejected
  MAINTENANCE     // maintenance ticket status changed
  APPLICATION     // application submitted / approved / rejected
  ACCOUNT         // account approved / deactivated
  ANNOUNCEMENT    // admin posted news
  GENERAL         // anything else
}

// ═══════════════════════════════════════════════════════════════
// MODELS
// ═══════════════════════════════════════════════════════════════

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         Role     @default(PENDING_STUDENT)
  name         String
  avatarUrl    String?
  university   String?
  program      String?
  year         Int?
  phone        String?
  bio          String?
  onboardedAt  DateTime?  // null = first-time user, show welcome tour
  isActive     Boolean   @default(true)  // admin-toggleable; false blocks login

  // ── Application fields (pending students only) ────────────────
  idNumber               String?            // SA ID number (13 digits)
  applicationStatus      ApplicationStatus  @default(DRAFT)
  applicationSubmittedAt DateTime?
  applicationApprovedAt  DateTime?
  applicationRejectedAt  DateTime?
  applicationAdminNote   String?            // reviewer's note on approve/reject

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  allocation         Allocation?
  maintenanceTickets MaintenanceTicket[]
  visitorPasses      VisitorPass[]
  choreLogs          ChoreLog[]
  wallet             Wallet?
  documents          Document[]
  auditLogs          AuditLog[]
  newsAuthored       News[]
  newsReads          NewsRead[]
  voucherClaims      VoucherClaim[]
  notifications      Notification[]
  passwordResets     PasswordResetToken[]

  @@index([role])
  @@index([email])
  // Indexed for the admin global-search (which matches name OR email).
  // Btree alone won't accelerate substring-ILIKE, but it helps exact +
  // prefix lookups today and lays the groundwork for a future pg_trgm
  // upgrade once any single residence has more than a few thousand rows.
  @@index([name])
}

// Single-use token issued by /api/auth/forgot-password and consumed by
// /api/auth/reset-password. Stored cryptographically random (32 bytes
// hex) and indexed for fast lookup. expiresAt is 1h from issue; usedAt
// goes non-null the moment the token is exchanged for a password
// change, so a reused link is a no-op (you can never reset twice with
// the same token).
//
// A user's older unused tokens are invalidated whenever they request a
// new reset — see passwordReset.service.ts.
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

// In-app notification — the persistent backbone of the notification
// centre (the bell dropdown). Created server-side alongside the
// best-effort emails, so a user always has a durable record even when
// email delivery is off / they were logged out when it happened.
model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType @default(GENERAL)
  title     String
  body      String?
  link      String?          // in-app route to open on click, e.g. "/documents"
  read      Boolean          @default(false)
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt])
}

model Room {
  id          String     @id @default(cuid())
  number      String     @unique
  block       String
  type        RoomType
  capacity    Int        @default(1)              // Number of tenants the room can hold
  price       Decimal    @db.Decimal(10, 2)
  status      RoomStatus @default(VACANT)
  residenceId String?                             // null until backfilled; will be enforced post-migration

  // Relations — a single Room can now have many Allocations (one per tenant)
  allocations Allocation[]
  residence   Residence?   @relation(fields: [residenceId], references: [id])

  @@index([block])
  @@index([status])
  @@index([residenceId])
  // Indexed for the global search (rooms by number / block).
  @@index([number])
}

model Allocation {
  id        String           @id @default(cuid())
  userId    String           @unique             // Each user has at most one current allocation
  roomId    String                                // No longer unique — many allocations may share a room
  status    AllocationStatus @default(RESERVED)
  moveIn    DateTime?
  rent      Decimal          @db.Decimal(10, 2)
  balance   Decimal          @default(0) @db.Decimal(10, 2)
  /// True = tenant tops up their own prepaid meter / smart electricity account.
  /// False (default) = admin buys electricity in bulk for the residence and bills back.
  electricitySelfManaged Boolean @default(false)

  // ── Lease lifecycle ──────────────────────────────────────────
  leaseStart        DateTime?              // start of the current lease term
  leaseEnd          DateTime?              // end of the current lease term
  depositAmount     Decimal?      @db.Decimal(10, 2)
  depositStatus     DepositStatus @default(NONE)
  depositRefunded   Decimal?      @db.Decimal(10, 2)  // amount returned at move-out
  depositNote       String?                            // e.g. "R500 withheld — carpet cleaning"
  noticeGivenAt     DateTime?              // when the tenant gave notice to vacate
  moveOutDate       DateTime?              // scheduled move-out date
  moveOutCompletedAt DateTime?             // set when move-out is actually completed

  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  // Relations
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  room        Room         @relation(fields: [roomId], references: [id])
  inspections Inspection[]

  @@index([roomId])
  @@index([status])
}

// A room-condition inspection tied to an allocation — move-in, routine,
// or move-out. Photos are stored on disk via storage.service.ts; the row
// holds the public /api/uploads/... URLs.
model Inspection {
  id           String         @id @default(cuid())
  allocationId String
  type         InspectionType
  inspectedAt  DateTime       @default(now())
  condition    String                          // "Good" | "Fair" | "Poor" — free text, kept simple
  notes        String?
  photoUrls    String[]       @default([])
  inspectorId  String?                          // staff member who carried it out
  createdAt    DateTime       @default(now())

  allocation Allocation @relation(fields: [allocationId], references: [id], onDelete: Cascade)

  @@index([allocationId])
}

model MaintenanceTicket {
  id          String       @id @default(cuid())
  studentId   String
  residenceId String?                            // derived from student's allocation at creation; null for orphan/legacy tickets
  category    String
  location    String
  description String
  priority    Priority     @default(NORMAL)
  status      TicketStatus @default(OPEN)
  mediaUrls   String[]
  adminNote   String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  // Relations
  student   User       @relation(fields: [studentId],   references: [id], onDelete: Cascade)
  residence Residence? @relation(fields: [residenceId], references: [id], onDelete: SetNull)
  updates   MaintenanceTicketUpdate[]

  @@index([studentId])
  @@index([status])
  @@index([priority])
  @@index([createdAt])
  // Indexed for the global search (category + location are the
  // searchable freeform fields on a ticket).
  @@index([category])
  @@index([location])
}

// Audit trail for ticket triage — one row per admin/manager/maintenance
// update so the ticket card surfaces a "who changed what when" timeline
// instead of overwriting state silently. The ticket itself still holds
// the CURRENT values; this table is purely additive history.
model MaintenanceTicketUpdate {
  id         String   @id @default(cuid())
  ticketId   String
  actorId    String?  // who made the change (admin / manager / maintenance staff). Null = system.
  actorName  String   // denormalised — survives the actor being deactivated/deleted.
  summary    String   // human-readable: "Status: OPEN → IN_PROGRESS · Note added".
  changes    Json     // structured: { status: {from, to}, adminNote: {from, to} } — for richer rendering.
  createdAt  DateTime @default(now())

  ticket MaintenanceTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId, createdAt])
}

model VisitorPass {
  id           String     @id @default(cuid())
  hostId       String
  visitorName  String
  visitorPhone String
  date         DateTime
  timeFrom     String
  timeTo       String
  purpose      String
  status       PassStatus @default(UPCOMING)
  checkedIn    Boolean    @default(false)
  checkedInAt  DateTime?
  qrCode       String     @unique
  createdAt    DateTime   @default(now())

  // Relations
  host User @relation(fields: [hostId], references: [id], onDelete: Cascade)

  @@index([hostId])
  @@index([status])
  @@index([date])
}

model Chore {
  id              String    @id @default(cuid())
  residenceId     String?                          // null = legacy / portfolio-wide; new chores get scoped
  icon            String
  name            String
  description     String
  frequency       String                           // Free-text, e.g. "Weekly · Tuesdays"
  block           String
  active          Boolean   @default(true)         // Admin can deactivate without deleting (preserves history)
  creditReward    Int       @default(20)           // Credits awarded on admin approval — per-chore tunable
  claimedById     String?
  doneById        String?
  doneAt          DateTime?
  // Proof + admin approval workflow
  proofUrl        String?
  proofStatus     String?   // PENDING | APPROVED | REJECTED
  proofSubmittedAt DateTime?
  approvalDeadline DateTime?
  approvedAt      DateTime?
  approvedById    String?
  adminNote       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  logs      ChoreLog[]
  residence Residence? @relation(fields: [residenceId], references: [id], onDelete: SetNull)

  @@index([block])
  @@index([proofStatus])
  @@index([residenceId])
}

model ChoreLog {
  id        String      @id @default(cuid())
  choreId   String
  userId    String
  action    ChoreAction
  note      String?
  createdAt DateTime    @default(now())

  // Relations
  chore Chore @relation(fields: [choreId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([choreId])
  @@index([userId])
  @@index([createdAt])
}

model Wallet {
  id        String   @id @default(cuid())
  userId    String   @unique
  credits   Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions WalletTransaction[]
}

model WalletTransaction {
  id        String          @id @default(cuid())
  walletId  String
  type      TransactionType
  amount    Int
  note      String
  createdAt DateTime        @default(now())

  // Relations
  wallet    Wallet             @relation(fields: [walletId], references: [id], onDelete: Cascade)
  redemption VoucherRedemption?

  @@index([walletId])
  @@index([createdAt])
}

model Voucher {
  id            String   @id @default(cuid())
  name          String
  description   String
  cost          Int
  icon          String
  stock         Int      @default(0)
  isActive      Boolean  @default(true)
  // Task-voucher fields
  requiresProof Boolean  @default(false)
  taskTitle     String?
  pin           String?
  imageUrl      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  redemptions VoucherRedemption[]
  claims      VoucherClaim[]
}

model VoucherClaim {
  id         String    @id @default(cuid())
  voucherId  String
  userId     String
  proofUrl   String?
  status     String    @default("PENDING")  // PENDING | APPROVED | REJECTED
  approvedBy String?
  approvedAt DateTime?
  adminNote  String?
  createdAt  DateTime  @default(now())

  // Relations
  voucher Voucher @relation(fields: [voucherId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId],    references: [id], onDelete: Cascade)

  @@unique([voucherId, userId])
  @@index([status])
  @@index([voucherId])
  @@index([userId])
}

model VoucherRedemption {
  id            String   @id @default(cuid())
  walletId      String
  voucherId     String
  transactionId String   @unique
  createdAt     DateTime @default(now())

  // Relations
  voucher     Voucher           @relation(fields: [voucherId], references: [id])
  transaction WalletTransaction @relation(fields: [transactionId], references: [id])

  @@index([walletId])
  @@index([voucherId])
}

model News {
  id          String   @id @default(cuid())
  residenceId String?                       // null = portfolio-wide announcement (visible to all)
  type        String
  tag         String
  tagColor    String   @default("#00CCCC")
  pinned      Boolean  @default(false)
  authorId    String
  title       String
  date        String
  body        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  author    User       @relation(fields: [authorId],   references: [id])
  residence Residence? @relation(fields: [residenceId], references: [id], onDelete: SetNull)
  reads     NewsRead[]

  @@index([pinned])
  @@index([createdAt])
  @@index([residenceId])
}

model NewsRead {
  id     String   @id @default(cuid())
  newsId String
  userId String
  readAt DateTime @default(now())

  // Relations
  news News @relation(fields: [newsId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([newsId, userId])
  @@index([userId])
}

model Document {
  id           String       @id @default(cuid())
  userId       String
  type         DocumentType
  period       String
  amount       String?
  status       String
  fileUrl      String?
  signedAt     DateTime?
  signedByName String?
  // Expiry — relevant for compliance docs (ID, proof of registration,
  // proof of funding). null = no expiry tracked. A daily cron warns the
  // student + admins as the date approaches.
  expiresAt    DateTime?
  expiryNotifiedAt DateTime?   // last time an expiry reminder was sent — de-dupes the cron
  // Compliance-doc review (per-doc verdict — distinct from the whole-application
  // decide flow). status moves Submitted → Approved | Rejected. On Rejected,
  // reviewNote carries the reason and the student is notified to re-upload.
  reviewedAt   DateTime?
  reviewedBy   String?      // admin User.id who decided
  reviewNote   String?      // rejection reason; optional on approve
  // Payment proof
  proofUrl     String?
  proofStatus  String?      // SUBMITTED | CLEARED | REJECTED
  clearedAt    DateTime?
  clearedBy    String?
  createdAt    DateTime     @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([proofStatus])
  @@index([expiresAt])
  @@index([status])
  // Indexed for the global search (invoices are looked up by period
  // string like "2026-05").
  @@index([period])
}

// Single-row settings table (id always = "settings")
model ResidenceSettings {
  id          String   @id @default("settings")
  name        String   @default("ResiHub Student Residence")
  tagline     String?
  address     String?
  phone       String?
  email       String?
  description String?

  // ── Recurring invoices ───────────────────────────────────────
  // When enabled, a daily cron raises that month's rent invoices for
  // every active student on `autoInvoiceDay` (1–28). bulkCreateInvoices
  // is idempotent, so a re-run never double-charges.
  autoInvoiceEnabled Boolean @default(false)
  autoInvoiceDay     Int     @default(1)
  autoInvoiceLastRun String?         // "YYYY-MM" of the last period generated

  updatedAt   DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  entity    String
  entityId  String?
  meta      Json?
  ip        String?
  createdAt DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([entity])
  @@index([createdAt])
}

// ═══════════════════════════════════════════════════════════════
// OPERATIONS — facility upkeep tracking (pool, gas, grass, etc.)
// ═══════════════════════════════════════════════════════════════

/// Each entry is one event: pool cleaned today, gas cylinder refilled,
/// R500 of electricity purchased, lawn cut by a contractor, etc.
/// `meta` holds type-specific blobs (litres, kWh, panel readings).
model OpsService {
  id          String         @id @default(cuid())
  residenceId String?                            // null = legacy / portfolio-wide
  type        OpsServiceType
  date        DateTime
  amount      Decimal?       @db.Decimal(10, 2)  // R cost; null for telemetry-only
  vendor      String?                            // e.g. "John's Pool Service"
  note        String?
  proofUrl    String?                            // base64 / receipt URL
  meta        Json?                              // {"litres":9,"kWh":24,...}
  createdById String                             // admin user id (audit)
  createdAt   DateTime       @default(now())

  residence Residence? @relation(fields: [residenceId], references: [id], onDelete: SetNull)

  @@index([type, date])
  @@index([date])
  @@index([residenceId])
}

/// Current stock level for consumables we want to know are running out
/// (chlorine, pH, gas in cylinder, prepaid electricity units).
model OpsStock {
  id          String   @id @default(cuid())
  residenceId String?                          // null = legacy single-residence data
  key         String                           // POOL_CHLORINE, POOL_PH, GAS_KG, ELECTRICITY_UNITS
  label       String                           // "Chlorine"
  quantity    Decimal  @db.Decimal(10, 2) @default(0)
  unit        String                           // "L", "kg", "kWh", "units"
  threshold   Decimal? @db.Decimal(10, 2)      // warn when below
  updatedAt   DateTime @updatedAt

  residence Residence? @relation(fields: [residenceId], references: [id], onDelete: SetNull)

  // Composite uniqueness so each residence has its own stock per key.
  @@unique([residenceId, key])
  @@index([residenceId])
}

/// A property an admin manages. One admin can manage many residences.
/// Health metrics + occupancy + ops can be viewed per-residence or rolled up.
model Residence {
  id          String   @id @default(cuid())
  name        String
  tagline     String?
  address     String?
  phone       String?
  email       String?
  description String?
  archived    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rooms       Room[]
  contractors ServiceContractor[]
  opsServices OpsService[]
  opsStock    OpsStock[]
  tickets     MaintenanceTicket[]
  news        News[]
  chores      Chore[]
}

/// Paid service workers — pool guy, cleaner, gardener, grounds-keeper.
/// Generates a recurring invoice each period that admin can mark paid.
model ServiceContractor {
  id          String                 @id @default(cuid())
  residenceId String
  type        ContractorType
  name        String
  phone       String?
  email       String?
  rate        Decimal                @db.Decimal(10, 2)
  rateUnit    String                 @default("month")    // month | week | visit
  paymentType ContractorPaymentType  @default(FIXED)      // FIXED = rate IS the invoice; VARIABLE = admin enters actual at pay-time
  startDate   DateTime
  endDate     DateTime?
  active      Boolean                @default(true)
  notes       String?
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  residence Residence            @relation(fields: [residenceId], references: [id], onDelete: Cascade)
  invoices  ContractorInvoice[]

  @@index([residenceId])
  @@index([type])
}

/// Invoice owed to a contractor for a period — generated by the system,
/// marked Paid by admin once they've actually paid the person.
model ContractorInvoice {
  id           String   @id @default(cuid())
  contractorId String
  period       String                                 // YYYY-MM
  amount       Decimal  @db.Decimal(10, 2)
  status       String   @default("Pending")          // Pending | Paid
  proofUrl     String?
  paidAt       DateTime?
  createdAt    DateTime @default(now())

  contractor ServiceContractor @relation(fields: [contractorId], references: [id], onDelete: Cascade)

  @@unique([contractorId, period])
  @@index([status])
}
