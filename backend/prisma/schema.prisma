// ResiHub — Prisma Schema
// Database: PostgreSQL 15+
// Last Updated: 2026-05-01

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════════════════════
// ENUMS
// ═══════════════════════════════════════════════════════════════

enum Role {
  ACTIVE_STUDENT
  PENDING_STUDENT
  ADMIN
}

enum RoomType {
  SINGLE
  DOUBLE
  TRIPLE
  QUAD
  STUDIO
}

enum RoomStatus {
  VACANT
  RESERVED
  OCCUPIED
}

enum AllocationStatus {
  RESERVED
  ACTIVE
  ENDED
}

enum Priority {
  LOW
  NORMAL
  HIGH
  EMERGENCY
}

/// Type of operational service / expense logged by admin.
/// Each type drives its own widget on the Operations tab.
enum OpsServiceType {
  POOL_CLEAN
  POOL_CHEMICAL
  GAS_REFILL
  GRASS_CUT
  ELECTRICITY_PURCHASE
  SOLAR_TELEMETRY
  OTHER
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum PassStatus {
  UPCOMING
  ACTIVE
  EXPIRED
  CANCELLED
}

enum ChoreAction {
  CLAIMED
  UNCLAIMED
  COMPLETED
}

enum TransactionType {
  EARN
  REDEEM
  ADJUST
}

enum DocumentType {
  INVOICE
  CONTRACT
  LETTER
}

// ═══════════════════════════════════════════════════════════════
// MODELS
// ═══════════════════════════════════════════════════════════════

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         Role     @default(PENDING_STUDENT)
  name         String
  avatarUrl    String?
  university   String?
  program      String?
  year         Int?
  phone        String?
  bio          String?
  onboardedAt  DateTime?  // null = first-time user, show welcome tour
  isActive     Boolean   @default(true)  // admin-toggleable; false blocks login
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  allocation         Allocation?
  maintenanceTickets MaintenanceTicket[]
  visitorPasses      VisitorPass[]
  choreLogs          ChoreLog[]
  wallet             Wallet?
  documents          Document[]
  auditLogs          AuditLog[]
  newsAuthored       News[]
  newsReads          NewsRead[]
  voucherClaims      VoucherClaim[]

  @@index([role])
  @@index([email])
}

model Room {
  id       String     @id @default(cuid())
  number   String     @unique
  block    String
  type     RoomType
  capacity Int        @default(1)              // Number of tenants the room can hold
  price    Decimal    @db.Decimal(10, 2)
  status   RoomStatus @default(VACANT)

  // Relations — a single Room can now have many Allocations (one per tenant)
  allocations Allocation[]

  @@index([block])
  @@index([status])
}

model Allocation {
  id        String           @id @default(cuid())
  userId    String           @unique             // Each user has at most one current allocation
  roomId    String                                // No longer unique — many allocations may share a room
  status    AllocationStatus @default(RESERVED)
  moveIn    DateTime?
  rent      Decimal          @db.Decimal(10, 2)
  balance   Decimal          @default(0) @db.Decimal(10, 2)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  room Room @relation(fields: [roomId], references: [id])

  @@index([roomId])
  @@index([status])
}

model MaintenanceTicket {
  id          String       @id @default(cuid())
  studentId   String
  category    String
  location    String
  description String
  priority    Priority     @default(NORMAL)
  status      TicketStatus @default(OPEN)
  mediaUrls   String[]
  adminNote   String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  // Relations
  student User @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([status])
  @@index([priority])
  @@index([createdAt])
}

model VisitorPass {
  id           String     @id @default(cuid())
  hostId       String
  visitorName  String
  visitorPhone String
  date         DateTime
  timeFrom     String
  timeTo       String
  purpose      String
  status       PassStatus @default(UPCOMING)
  checkedIn    Boolean    @default(false)
  checkedInAt  DateTime?
  qrCode       String     @unique
  createdAt    DateTime   @default(now())

  // Relations
  host User @relation(fields: [hostId], references: [id], onDelete: Cascade)

  @@index([hostId])
  @@index([status])
  @@index([date])
}

model Chore {
  id              String    @id @default(cuid())
  icon            String
  name            String
  description     String
  frequency       String
  block           String
  claimedById     String?
  doneById        String?
  doneAt          DateTime?
  // Proof + admin approval workflow
  proofUrl        String?
  proofStatus     String?   // PENDING | APPROVED | REJECTED
  proofSubmittedAt DateTime?
  approvalDeadline DateTime?
  approvedAt      DateTime?
  approvedById    String?
  adminNote       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  logs ChoreLog[]

  @@index([block])
  @@index([proofStatus])
}

model ChoreLog {
  id        String      @id @default(cuid())
  choreId   String
  userId    String
  action    ChoreAction
  note      String?
  createdAt DateTime    @default(now())

  // Relations
  chore Chore @relation(fields: [choreId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([choreId])
  @@index([userId])
  @@index([createdAt])
}

model Wallet {
  id        String   @id @default(cuid())
  userId    String   @unique
  credits   Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions WalletTransaction[]
}

model WalletTransaction {
  id        String          @id @default(cuid())
  walletId  String
  type      TransactionType
  amount    Int
  note      String
  createdAt DateTime        @default(now())

  // Relations
  wallet    Wallet             @relation(fields: [walletId], references: [id], onDelete: Cascade)
  redemption VoucherRedemption?

  @@index([walletId])
  @@index([createdAt])
}

model Voucher {
  id            String   @id @default(cuid())
  name          String
  description   String
  cost          Int
  icon          String
  stock         Int      @default(0)
  isActive      Boolean  @default(true)
  // Task-voucher fields
  requiresProof Boolean  @default(false)
  taskTitle     String?
  pin           String?
  imageUrl      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  redemptions VoucherRedemption[]
  claims      VoucherClaim[]
}

model VoucherClaim {
  id         String    @id @default(cuid())
  voucherId  String
  userId     String
  proofUrl   String?
  status     String    @default("PENDING")  // PENDING | APPROVED | REJECTED
  approvedBy String?
  approvedAt DateTime?
  adminNote  String?
  createdAt  DateTime  @default(now())

  // Relations
  voucher Voucher @relation(fields: [voucherId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId],    references: [id], onDelete: Cascade)

  @@unique([voucherId, userId])
  @@index([status])
  @@index([voucherId])
  @@index([userId])
}

model VoucherRedemption {
  id            String   @id @default(cuid())
  walletId      String
  voucherId     String
  transactionId String   @unique
  createdAt     DateTime @default(now())

  // Relations
  voucher     Voucher           @relation(fields: [voucherId], references: [id])
  transaction WalletTransaction @relation(fields: [transactionId], references: [id])

  @@index([walletId])
  @@index([voucherId])
}

model News {
  id        String   @id @default(cuid())
  type      String
  tag       String
  tagColor  String   @default("#00CCCC")
  pinned    Boolean  @default(false)
  authorId  String
  title     String
  date      String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  author User       @relation(fields: [authorId], references: [id])
  reads  NewsRead[]

  @@index([pinned])
  @@index([createdAt])
}

model NewsRead {
  id     String   @id @default(cuid())
  newsId String
  userId String
  readAt DateTime @default(now())

  // Relations
  news News @relation(fields: [newsId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([newsId, userId])
  @@index([userId])
}

model Document {
  id           String       @id @default(cuid())
  userId       String
  type         DocumentType
  period       String
  amount       String?
  status       String
  fileUrl      String?
  signedAt     DateTime?
  signedByName String?
  // Payment proof
  proofUrl     String?
  proofStatus  String?      // SUBMITTED | CLEARED | REJECTED
  clearedAt    DateTime?
  clearedBy    String?
  createdAt    DateTime     @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([proofStatus])
}

// Single-row settings table (id always = "settings")
model ResidenceSettings {
  id          String   @id @default("settings")
  name        String   @default("ResiHub Student Residence")
  tagline     String?
  address     String?
  phone       String?
  email       String?
  description String?
  updatedAt   DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  entity    String
  entityId  String?
  meta      Json?
  ip        String?
  createdAt DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([entity])
  @@index([createdAt])
}

// ═══════════════════════════════════════════════════════════════
// OPERATIONS — facility upkeep tracking (pool, gas, grass, etc.)
// ═══════════════════════════════════════════════════════════════

/// Each entry is one event: pool cleaned today, gas cylinder refilled,
/// R500 of electricity purchased, lawn cut by a contractor, etc.
/// `meta` holds type-specific blobs (litres, kWh, panel readings).
model OpsService {
  id          String         @id @default(cuid())
  type        OpsServiceType
  date        DateTime
  amount      Decimal?       @db.Decimal(10, 2)  // R cost; null for telemetry-only
  vendor      String?                            // e.g. "John's Pool Service"
  note        String?
  proofUrl    String?                            // base64 / receipt URL
  meta        Json?                              // {"litres":9,"kWh":24,...}
  createdById String                             // admin user id (audit)
  createdAt   DateTime       @default(now())

  @@index([type, date])
  @@index([date])
}

/// Current stock level for consumables we want to know are running out
/// (chlorine, pH, gas in cylinder, prepaid electricity units).
model OpsStock {
  id        String   @id @default(cuid())
  key       String   @unique             // POOL_CHLORINE, POOL_PH, GAS_KG, ELECTRICITY_UNITS
  label     String                       // "Chlorine"
  quantity  Decimal  @db.Decimal(10, 2) @default(0)
  unit      String                       // "L", "kg", "kWh", "units"
  threshold Decimal? @db.Decimal(10, 2)  // warn when below
  updatedAt DateTime @updatedAt
}
